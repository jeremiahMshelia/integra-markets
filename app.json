{
  "expo": {
    "name": "Integra Markets",
    "slug": "integra",
    "scheme": "com.centori.integramarkets",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/NewLogoInt.png.png",
    "userInterfaceStyle": "light",
    "description": "Professional financial markets analysis and news aggregation platform with AI-powered sentiment analysis for commodities trading.",
    "keywords": [
      "finance",
      "markets",
      "trading",
      "commodities",
      "news",
      "analysis",
      "AI",
      "sentiment"
    ],
    "category": "finance",
    "privacy": "https://integramarkets.com/privacy",
    "splash": {
      "backgroundColor": "#121212"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.centori.integramarkets",
      "buildNumber": "62",
      "deploymentTarget": "13.0",
      "supportsTablet": true,
      "requireFullScreen": false,
      "appStoreUrl": "https://apps.apple.com/app/integra-markets/id123456789",
      "category": "finance",
      "runtimeVersion": "1.0.0",
      "jsEngine": "hermes",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.centori.integramarkets",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/NewLogoInt.png.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.USE_FINGERPRINT"
      ],
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "favicon": "./assets/NewLogoInt.png.png",
      "bundler": "metro",
      "output": "single",
      "baseUrl": "/integra-markets"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/NewLogoInt.png.png",
          "color": "#4ECCA3",
          "defaultChannel": "default"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.908401428746-rl14nd024rems2rmkgbnke0firp2mdab"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Integra Markets needs access to your photos to update your profile picture."
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "$EXPO_PUBLIC_SUPABASE_URL",
      "supabaseAnonKey": "$EXPO_PUBLIC_SUPABASE_ANON_KEY",
      "apiUrl": "$EXPO_PUBLIC_API_URL",
      "groqApiKey": "$EXPO_PUBLIC_GROQ_API_KEY",
      "huggingFaceToken": "$EXPO_PUBLIC_HUGGING_FACE_TOKEN",
      "googleIosClientId": "$GOOGLE_IOS_CLIENT_ID",
      "googleAndroidClientId": "$GOOGLE_ANDROID_CLIENT_ID",
      "googleWebClientId": "$GOOGLE_WEB_CLIENT_ID",
      "eas": {
        "projectId": "d015a7d9-68a1-47a8-8ed4-217d8a0732af"
      }
    },
    "newArchEnabled": false,
    "owner": "pipscobar"
  }
}