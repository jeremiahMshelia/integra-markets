{
  "name": "@integra-markets/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript client for the Integra Markets API — commodity sentiment + prediction-market connectors.",
  "author": {
    "name": "Integra Markets",
    "email": "contact@integramarkets.app",
    "url": "https://integramarkets.app"
  },
  "license": "Apache-2.0",
  "homepage": "https://docs.integramarkets.app",
  "repository": {
