# ===========================================
# INTEGRA MARKETS - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# SUPABASE (Required)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key-here

# For Expo app (same values with EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ===========================================
# AI SERVICES (Required)
# ===========================================
HUGGING_FACE_TOKEN=hf_your_token_here
GROQ_API_KEY=gsk_your_groq_key_here
EXPO_PUBLIC_HUGGING_FACE_TOKEN=hf_your_token_here
EXPO_PUBLIC_GROQ_API_KEY=gsk_your_groq_key_here

# ===========================================
# NEWS (Optional)
# ===========================================
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key-here

# ===========================================
# BACKEND URL
# ===========================================
EXPO_PUBLIC_API_URL=https://integra-markets.onrender.com

# ===========================================
# GOOGLE SIGN-IN (For native in-app login)
# ===========================================
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client IDs for iOS, Web, and Android

# iOS Client ID (Bundle ID: com.centori.integramarkets)
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Web Client ID (Required for ID tokens)
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Android Client ID (Package: com.centori.integramarkets)
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
