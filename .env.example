# ===========================================
# INTEGRA MARKETS - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit your .env file to git!

# ===========================================
# SUPABASE
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Expo app (same values with prefix)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ===========================================
# AI SERVICES
# ===========================================
HUGGING_FACE_TOKEN=your-huggingface-token
GROQ_API_KEY=your-groq-api-key
EXPO_PUBLIC_HUGGING_FACE_TOKEN=your-huggingface-token
EXPO_PUBLIC_GROQ_API_KEY=your-groq-api-key

# ===========================================
# NEWS API
# ===========================================
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key

# ===========================================
# BACKEND
# ===========================================
EXPO_PUBLIC_API_URL=https://integra-markets-9zz1.onrender.com

# ===========================================
# GOOGLE SIGN-IN (Optional - for native in-app login)
# ===========================================
GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# ===========================================
# EMAIL ALERTS (Choose ONE option)
# ===========================================
# Option 1: Resend (Easy setup - https://resend.com, free tier: 100 emails/day)
RESEND_API_KEY=re_xxxxx

# Option 2: Zoho Mail (If you have Zoho access)
# ZOHO_MAIL_FROM_EMAIL=alerts@integra-markets.com
# ZOHO_MAIL_APP_PASSWORD=your-zoho-app-password
